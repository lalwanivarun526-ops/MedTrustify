body {
  font-family: Arial;
  margin: 0;
  background: #f5f5f5;
}

header {
  background: #0a2540;
  color: white;
  padding: 15px;
  text-align: center;
}

nav a {
  color: white;
  margin: 10px;
  text-decoration: none;
}

.container {
  padding: 20px;
}

.card {
  background: white;
  padding: 15px;
  margin: 15px 0;
  border-radius: 8px;
}

.btn {
  background: orange;
  padding: 10px;
  color: white;
  text-decoration: none;
  border-radius: 5px;
}

footer {
  text-align: center;
  padding: 10px;
}
